// cuda.npk — C-FFI bindings to CUDA Runtime

// Memory copy types:
// 0: HostToHost, 1: HostToDevice, 2: DeviceToHost, 3: DeviceToDevice
pub fixed int32:CUDA_MEMCPY_H2D = 1i32;
pub fixed int32:CUDA_MEMCPY_D2H = 2i32;

extern "C" {
    // cudaError_t cudaMemcpyAsync(void* dst, const void* src, size_t count, cudaMemcpyKind kind, cudaStream_t stream = 0)
    func:cuMemcpyAsync = int32(void*:dst, void*:src, uint64:count_bytes, int32:kind, uint64:stream_id);
    
    // cudaError_t cudaStreamSynchronize(cudaStream_t stream)
    func:cuStreamSynchronize = int32(int64:stream_id);

    // cudaError_t cudaStreamCreate(cudaStream_t *pStream)
    func:cuStreamCreate = int32(uint64*:pStream);
    
    // cudaError_t cudaStreamDestroy(cudaStream_t stream)
    func:cuStreamDestroy = int32(uint64:stream_id);
    
    // cudaError_t cudaMalloc(void** devPtr, size_t size)
    func:cuMemAlloc = int32(void**:devPtr, uint64:size);
    
    // cudaError_t cudaFree(void* devPtr)
    func:cuMemFree = int32(void*:devPtr);
}
