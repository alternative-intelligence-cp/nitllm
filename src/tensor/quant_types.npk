// quant_types.npk — INT4 specific weight layouts

use "../util/error_codes.npk".*;

// INT4 values are packed 2-per-byte. 
// We represent the raw storage block as a byte array (int8), 
// which will be unpacked strictly via PTX kernels, not CPU code.
pub struct:PackedInt4Block = {
    int8[64]:data;           // 64 bytes  
    uint16:scale_bits;       // 2 bytes (bitcasted to FP16 in PTX)  
    int4:zero_point;         // 1 byte (packed)  
    int8[61]:padding;        // 61 bytes padding = exactly 128 bytes  
};

// A raw tensor representation pointing to VRAM.
// Note: We use wild pointers, NOT Handle<T>, to prevent massive metadata OOM.
pub struct:TensorINT4 = {
    wild int8->:raw_data;
    int64:num_blocks;
    int64:stride;
};
