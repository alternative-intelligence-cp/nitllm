// alloc_kv.npk — KV Cache allocations

use "../util/error_codes.npk".*;
use "dense.npk".*;
use "../ffi/cuda.npk".*;

pub func:allocate_mla_cache = int64(int64:capacity_elements) {
    tbb64:safe_cap = capacity_elements => tbb64;  
    tbb64:bytes_tbb = safe_cap * 4tbb64;  
    if (bytes_tbb == ERR) { fail(ERR_OOM_VRAM); }

    int64:bytes = bytes_tbb => int64;  
    
    int64:dev_ptr = shim_cuMemAlloc(@cast_unchecked<uint64>(bytes));
    if (dev_ptr == 0i64) { fail(ERR_OOM_VRAM); }
    
    pass(dev_ptr);
};
