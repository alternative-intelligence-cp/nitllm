// alloc_kv.npk — KV Cache allocations

use "../util/error_codes.npk".*;
use "dense.npk".*;

// Returns raw wild pointer. Implicitly wrapped in Result<wild flt32->>.
// Ownership transferred to caller; no defer free here. (Fixes UAF Audit 1.1)
pub func:allocate_mla_cache = wild flt32->(int64:capacity_elements) {
    
    // Allocation bypasses GC tracking entirely. Capacity is elements, not bytes.
    // (Fixes Type Confusion & Size Bug Audit 1.3)
    wild int8->:bytes = alloc(capacity_elements * 4i64)?!; // 4 bytes per flt32  
    wild flt32->:raw_buffer = bytes => wild flt32->;
    
    // Explicitly pass the pointer back up the chain
    pass(raw_buffer);
};
