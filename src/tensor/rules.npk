// rules.npk — Z3 verified limit rules

// A valid Mamba chunk stride must be exactly divisible by 64, greater than 0, and <= 4096.
// Using Z3 '--smt-opt' to prove these limits at compile time where possible.
pub Rules<int32>:valid_stride = { $ > 0i32, $ <= 4096i32, $ % 64i32 == 0i32 };

// A valid blocks size. 
pub Rules<int64>:valid_blocks = { $ > 0i64, $ <= 2000000000i64 }; 
