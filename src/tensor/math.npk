// math.npk
use "dense.npk".*;

pub func:vector_add = NIL(wild flt32->:a, wild flt32->:b, wild flt32->:out, int64:len) requires len > 0i64 {    
    int64:i = 0i64;    
    int64:simd_len = len - (len % 16i64); 

    wild simd<flt32, 16>->:simd_a = a => simd<flt32, 16>->;    
    wild simd<flt32, 16>->:simd_b = b => simd<flt32, 16>->;    
    wild simd<flt32, 16>->:simd_out = out => simd<flt32, 16>->;

    int64:vec_idx = 0i64;  
    while (i < simd_len) {    
        simd_out[vec_idx] = simd_a[vec_idx] + simd_b[vec_idx];    
        i = i + 16i64;    
        vec_idx = vec_idx + 1i64;  
    }  

    while (i < len) {  
        out[i] = a[i] + b[i];  
        i = i + 1i64;  
    }  
    pass(NIL);    
};

pub func:vector_mul = NIL(wild flt32->:a, wild flt32->:b, wild flt32->:out, int64:len) {
    _?stddbg.write("Vector mul executed\n");
    pass(NIL);
};

pub func:scalar_broadcast = NIL() { pass(NIL); }
