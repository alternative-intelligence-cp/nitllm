// src/structs/arena.npk — Generational Arena allocator
use "tcb.npk".TCB;
use "handle.npk".IdxHandle;
use "memory_helpers.npk".*;

pub struct:ArenaSlot = {
    TCB: item;
    int32: generation;
    int64: next_free;
    bool: occupied;
};

pub struct:TCBArena = {
    wild ArenaSlot->: slots; // Explicitly marked wild for calloc mapping
    int64: capacity;
    int64: count;
    int64: first_free;
};

pub func:arena_init = NIL(TCBArena->:arena) {
    arena->capacity = 1024i64;
    arena->count = 0i64;
    arena->first_free = 0i64;

    arena->slots = calloc(1024i64, 104i64) => ArenaSlot->; // explicitly 104 bytes per slot!
    int64: base = raw(ptr_to_int(arena->slots => any->));

    int64: i = 0i64;
    while (i < 1024i64) {
        int64: slot_ptr = base + (i * 104i64);
        int64: next_val = i + 1i64;

        _?write_int32(slot_ptr + 80i64, 1i32); // generation
        _?write_bool(slot_ptr + 96i64, false); // occupied
        _?write_int64(slot_ptr + 88i64, next_val); // next_free
        i = i + 1i64;
    }

    int64: last_ptr = base + (1023i64 * 104i64);
    _?write_int64(last_ptr + 88i64, -1i64);

    pass(NIL);
};

pub func:tcb_arena_allocate = IdxHandle<TCB>(TCBArena->:arena) {
    if (arena->first_free == -1i64) {
        IdxHandle<TCB>: invalid;
        invalid.index = -1i64;
        invalid.generation = 0i32;
        pass(invalid);
    }

    int64: idx = arena->first_free;
    int64: base = raw(ptr_to_int(arena->slots => any->));
    int64: slot_ptr = base + (idx * 104i64);

    int64: next_free_val = raw(read_int64(slot_ptr + 88i64));
    arena->first_free = next_free_val;

    _?write_bool(slot_ptr + 96i64, true);
    _?write_int64(slot_ptr + 88i64, -1i64);

    arena->count = arena->count + 1i64;

    IdxHandle<TCB>: h;
    h.index = idx;
    int32: gen_val = raw(read_int32(slot_ptr + 80i64));
    h.generation = gen_val;

    pass(h);
};

pub func:tcb_arena_get = TCB->(TCBArena->:arena, IdxHandle<TCB>:h) {
    if (h.index < 0i64) { pass(NULL); }
    if (h.index >= 1024i64) { pass(NULL); }

    int64: base = raw(ptr_to_int(arena->slots => any->));
    int64: slot_ptr = base + (h.index * 104i64);

    bool: occ = raw(read_bool(slot_ptr + 96i64));
    if (!occ) { pass(NULL); }

    int32: gen_val = raw(read_int32(slot_ptr + 80i64));
    if (gen_val != h.generation) { pass(NULL); }

    // TCB is at offset 0
    int64: p = base + (h.index * 104i64); 
    TCB->: item_ptr = p => TCB->;
    pass(item_ptr);
};

pub func:tcb_arena_release = bool(TCBArena->:arena, IdxHandle<TCB>:h) {
    if (h.index < 0i64) { pass(false); }
    if (h.index >= 1024i64) { pass(false); }

    int64: base = raw(ptr_to_int(arena->slots => any->));
    int64: slot_ptr = base + (h.index * 104i64);

    bool: occ = raw(read_bool(slot_ptr + 96i64));
    if (!occ) { pass(false); }

    int32: gen_val = raw(read_int32(slot_ptr + 80i64));
    if (gen_val != h.generation) { pass(false); }

    _?write_bool(slot_ptr + 96i64, false);
    _?write_int32(slot_ptr + 80i64, gen_val + 1i32);
    _?write_int64(slot_ptr + 88i64, arena->first_free);

    arena->first_free = h.index;
    arena->count = arena->count - 1i64;

    pass(true);
};
